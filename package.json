{
  "name": "kazura",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    },
    "./*/*": {
      "types": "./dist/*/*/index.d.ts",
      "default": "./dist/*/*/index.js"
    }
  },
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
